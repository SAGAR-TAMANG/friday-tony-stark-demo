# LiveKit credentials (get from https://cloud.livekit.io)
LIVEKIT_URL=wss://your-project-xxxxx.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sarvam AI key for default speech-to-text
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI key for default LLM, TTS, and screen vision
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx

# Optional provider keys
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPGRAM_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# FRIDAY memory and workspace
OBSIDIAN_VAULT_PATH=/Users/you/Desktop/SecBrain
WORKSPACE_ROOTS=/Users/you/Desktop

# Human-worker desktop automation
OPENAI_VISION_MODEL=gpt-4o
FRIDAY_REQUIRE_CONFIRMATION=true
FRIDAY_SCREENSHOT_DIR=/tmp/friday-screens

# Optional email defaults
FRIDAY_EMAIL_SUBJECT=Message from FRIDAY
