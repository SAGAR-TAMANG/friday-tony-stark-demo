# =============================================================================
# F.R.I.D.A.Y. — environment variables
# =============================================================================
# Copy this file to `.env` and fill in only what you need. Every category
# below has a keyless fallback that works out of the box, so most sections
# are optional.
# =============================================================================

# -----------------------------------------------------------------------------
# LiveKit (required for voice)
# -----------------------------------------------------------------------------
LIVEKIT_URL=wss://your-project-xxxxx.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# MCP transport
#   streamable-http (default, current spec) | sse (deprecated, legacy clients)
# -----------------------------------------------------------------------------
MCP_TRANSPORT=streamable-http
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8000

# -----------------------------------------------------------------------------
# Voice mode
#   pipeline         — STT + LLM + TTS chain (default, most robust)
#   realtime_gemini  — Gemini Live speech-to-speech (~300 ms latency)
#   realtime_openai  — OpenAI Realtime speech-to-speech (~300 ms latency)
# -----------------------------------------------------------------------------
VOICE_MODE=pipeline

# -----------------------------------------------------------------------------
# Pipeline provider selection (ignored in realtime modes)
# -----------------------------------------------------------------------------
STT_PROVIDER=sarvam          # sarvam | openai | whisper
LLM_PROVIDER=gemini          # gemini | openai | ollama
TTS_PROVIDER=openai          # openai | sarvam

# Model overrides — bump as new models ship.
GEMINI_LLM_MODEL=gemini-2.5-pro
OPENAI_LLM_MODEL=gpt-4.1
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434/v1
GEMINI_REALTIME_MODEL=gemini-2.5-flash-live
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_STT_MODEL=gpt-4o-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=ash
TTS_SPEED=1.1

# -----------------------------------------------------------------------------
# Provider API keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx
GOOGLE_API_KEY=your-google-api-key     # https://aistudio.google.com/projects
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx
DEEPGRAM_API_KEY=

# -----------------------------------------------------------------------------
# Web search fallback chain (all optional — DuckDuckGo works keyless)
# -----------------------------------------------------------------------------
TAVILY_API_KEY=
BRAVE_API_KEY=
SERPAPI_KEY=

# -----------------------------------------------------------------------------
# News (all optional — GDELT + RSS work keyless)
# -----------------------------------------------------------------------------
NEWSAPI_KEY=

# -----------------------------------------------------------------------------
# Finance (optional — yfinance + CoinGecko work keyless)
# -----------------------------------------------------------------------------
FINNHUB_API_KEY=

# -----------------------------------------------------------------------------
# Weather (optional — Open-Meteo works keyless)
# -----------------------------------------------------------------------------
OPENWEATHERMAP_API_KEY=

# -----------------------------------------------------------------------------
# Push notifications (Telegram bot — https://core.telegram.org/bots)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Google APIs (OAuth — download credentials JSON from Google Cloud Console)
# -----------------------------------------------------------------------------
GMAIL_CREDENTIALS_JSON=
GMAIL_TOKEN_JSON=friday_gmail_token.json
GOOGLE_CALENDAR_CREDENTIALS_JSON=
GOOGLE_CALENDAR_TOKEN_JSON=friday_calendar_token.json

# Service-account JSON for Google STT (only if STT_PROVIDER=google)
GOOGLE_APPLICATION_CREDENTIALS=

# -----------------------------------------------------------------------------
# FRIDAY Data Paths (optional — defaults to ~/.friday)
# -----------------------------------------------------------------------------
FRIDAY_HOME=~/.friday
FRIDAY_DB_PATH=~/.friday/databases
FRIDAY_MEMORY_PATH=~/.friday/memory.json

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
# Enable/disable shell execution tool
SHELL_EXEC_ENABLED=true
# Comma-separated list of blocked commands (partial match)
SHELL_BLOCKED_COMMANDS=rm -rf /,rm -rf /*,dd if=/dev/zero,:(){ :|:& };:

# -----------------------------------------------------------------------------
# A2A Protocol (Agent-to-Agent communication)
# -----------------------------------------------------------------------------
A2A_ENABLED=false
A2A_PORT=8001

# -----------------------------------------------------------------------------
# Orchestrator / memory backend (all optional)
# -----------------------------------------------------------------------------
# Sandbox for file tools. Defaults to FRIDAY_HOME.
FRIDAY_FILE_ROOT=
# Enable python runner tool (off by default — opt-in only).
CODE_EXEC_ENABLED=false
# Allow the db tool to write. Read-only by default.
DB_WRITE_ENABLED=false
# Split models for planner (quality) and executor (cost/latency).
PLANNER_MODEL=gemini-2.5-pro
EXECUTOR_MODEL=gemini-2.5-flash
# Memory backend: json (default, zero deps) | faiss | chroma.
MEMORY_BACKEND=json
# Route voice agent through orchestrator instead of direct LLM.
USE_ORCHESTRATOR=false

# -----------------------------------------------------------------------------
# Optional Tool Dependencies
# -----------------------------------------------------------------------------
# Install with: pip install friday[browser] or uv sync --extra browser
# PLAYWRIGHT_BROWSERS_PATH=0  # Use system Chromium

# -----------------------------------------------------------------------------
# Supabase (optional — ticketing demo tool)
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_API_KEY=
